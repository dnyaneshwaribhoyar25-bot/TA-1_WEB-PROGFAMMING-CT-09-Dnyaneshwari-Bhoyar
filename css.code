<style>
body {
    font-family: Arial, sans-serif;
    margin: 0;
    background-color: #f4f4f4;
}

table {
    border-collapse: collapse;
}

.header {
    background-color: #333;
    color: white;
    text-align: center;
}

.header a {
    text-decoration: none;
    margin: 0 10px;
    font-weight: bold;
}

.banner {
    background-color: #ff9800;
    text-align: center;
    color: white;
}

.banner button {
    background-color: white;
    color: #ff9800;
