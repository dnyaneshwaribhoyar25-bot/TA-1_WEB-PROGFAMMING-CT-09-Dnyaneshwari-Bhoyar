    font-weight: bold;
}

.products {
    background-color: #ffffff;
    text-align: center;
}

.product-box {
    background-color: #fafafa;
    border-radius: 10px;
}

.product-box img {
    border-radius: 10px;
}

.product-box button {
    background-color: #4CAF50;
    color: white;
    border: none;
    padding: 8px 15px;
